# ============================================
# Stride28 环境变量配置
# 复制此文件为 .env 并填入你的 API Keys
# cp .env.example .env
# ============================================

# ============================================
# LLM Provider API Keys（至少配置一个）
# ============================================

# DeepSeek（推荐，性价比最高）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# DashScope / 通义千问（Embedding 必须配置）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# OpenAI（可选）
# OPENAI_API_KEY=sk-your-openai-api-key

# 智谱 GLM（可选）
# ZHIPU_API_KEY=sk-your-zhipu-api-key


# ============================================
# LangSmith 追踪（可选，推荐开启）
# ============================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_pt_your-langsmith-api-key
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-api-key
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=Stride28
LANGSMITH_PROJECT=Stride28

# ============================================
# 应用配置
# ============================================

# GitHub Personal Access Token（可选，提升 API 速率限制：无 token 10次/分钟，有 token 30次/分钟）
# GITHUB_TOKEN=ghp_your-github-token

# 默认 LLM Provider（可选值：deepseek / openai / zhipu / tongyi）
DEFAULT_PROVIDER=deepseek

# Embedding Provider（固定使用 tongyi/text-embedding-v2，不可随意切换）
# 切换 Embedding 模型会导致 ChromaDB 向量不兼容，需要清空重建
EMBEDDING_PROVIDER=tongyi

# 默认模型
DEFAULT_MODEL=deepseek-chat

# 数据存储路径
DATA_DIR=./data

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=./data/chroma

# ============================================
# Reranker 配置（可选，不安装 FlagEmbedding 时自动禁用）
# ============================================
RERANKER_ENABLED=true
RERANKER_MODEL_PATH=BAAI/bge-reranker-v2-m3

# ============================================
# Tavily 通用网页搜索（可选，免费 1000 credits/月）
# ============================================
# TAVILY_API_KEY=tvly-xxxxx
